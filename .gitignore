*.db
/tests/Support/Data/sessions/
/.docker/*.env
/data/cache/
/data/*.log
/src/assets/
/vendor/
/src/config.ini
/todos.md

# Ignore user-installed themes; the repo ships 'base', '2024', and '2026'.
# Ignore unknown subdirectories only — never the parent — so that git add
# on tracked theme files works without -f.
src/themes/*/
!src/themes/base/
!src/themes/2024/
!src/themes/2026/
.env

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Docs
/.jekyll-bundle/
/docs/_site/
/docs/.bundle/
/docs/.jekyll-cache/
/docs/vendor/
/docs/Gemfile.lock

# pnpm store created when running inside the Workshop env
/.pnpm-store/

# Local agent/tooling state
/.serena/
/.claude/settings.local.json

# Local runtime data (db is covered by *.db above)
/data/sessions/
